#%Module 1.0

module-whatis "LCM GCC compiler"

setenv TOOL_CHAIN gcc

if { [is-loaded lcm-cee] } {
  # On CEE LAN, load the SEMS GCC module
  module load sems-gcc/13.2.0
  setenv CC [exec which gcc]
  setenv CXX [exec which g++]
  setenv FC [exec which gfortran]
} elseif { [ file exists /opt/rh/gcc-toolset-15/root/usr/bin/gcc ] } {
  # Use GCC 15 via gcc-toolset-15 (Rigel/standalone RHEL)
  # Prepend to PATH so MPI wrappers (mpicxx, mpif90) find these compilers
  prepend-path PATH /opt/rh/gcc-toolset-15/root/usr/bin
  prepend-path LD_LIBRARY_PATH /opt/rh/gcc-toolset-15/root/usr/lib64
  setenv CC /opt/rh/gcc-toolset-15/root/usr/bin/gcc
  setenv CXX /opt/rh/gcc-toolset-15/root/usr/bin/g++
  setenv FC /opt/rh/gcc-toolset-15/root/usr/bin/gfortran
} else {
  setenv CC [exec which gcc]
  setenv CXX [exec which g++]
  setenv FC [exec which gfortran]
}

if { [is-loaded lcm-fedora] } {
  setenv CXXFLAGS "-std=c++20 -Wno-terminate -Wno-deprecated-declarations"
} else {
  setenv CXXFLAGS "-std=c++20"
}
