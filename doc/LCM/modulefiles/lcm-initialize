#%Module 1.0
if { [ file exists /etc/fedora-release ] } {
  module load lcm-fedora
} elseif { [ file exists /etc/redhat-release ] } {
  set hn [info hostname]
  if { [string match "hpws*" $hn] || [string match "cee-*" $hn] } {
    module load lcm-cee
  } else {
    module load lcm-rhel
  }
} elseif { [ file exists /etc/lsb-release ] } {
  module load lcm-ubuntu
}
