#!/bin/bash
# LCM Build System CLI
# Usage: lcm <command> [package] [threads]
#   lcm clean trilinos        - Clean trilinos build/install
#   lcm clean lcm             - Clean lcm build
#   lcm config trilinos [N]   - Configure trilinos
#   lcm config lcm [N]        - Configure lcm
#   lcm build trilinos [N]    - Build trilinos with N threads
#   lcm build lcm [N]         - Build lcm with N threads
#   lcm test lcm              - Run lcm tests
#   lcm all [N]               - Full pipeline: clean + config + build + test
#   lcm help                  - Show this help

set -e

#---------------------------------------------------------------------------
# Resolve LCM_DIR: workspace root that contains the LCM repo directory.
# If LCM_DIR is already set, honour it; otherwise derive from script path
# or fall back to the current working directory.
#---------------------------------------------------------------------------
if [ -z "$LCM_DIR" ]; then
    # Script lives in <workspace>/LCM/doc/LCM/build/lcm
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    CANDIDATE="$(cd "$SCRIPT_DIR/../../../../.." && pwd)"
    if [ -d "$CANDIDATE/LCM/doc/LCM" ]; then
        export LCM_DIR="$CANDIDATE"
    else
        export LCM_DIR="$(pwd)"
    fi
fi

#---------------------------------------------------------------------------
# Module environment
#---------------------------------------------------------------------------
MODULE_NAME="${LCM_MODULE:-release}"
export MODULEPATH="$LCM_DIR/LCM/doc/LCM/modulefiles${MODULEPATH:+:$MODULEPATH}"

# Source the module init if 'module' is not already a function/command
if ! type module &>/dev/null; then
    if [ -f /usr/share/Modules/init/bash ]; then
        source /usr/share/Modules/init/bash
    elif [ -f /usr/share/modules/init/bash ]; then
        source /usr/share/modules/init/bash
    elif [ -f /etc/profile.d/modules.sh ]; then
        source /etc/profile.d/modules.sh
    else
        echo "ERROR: Cannot find Environment Modules init script."
        echo "Install environment-modules or set module paths manually."
        exit 1
    fi
fi

# On CEE LAN machines, initialize Lmod (via SEMS) and load compiler/TPL
# modules.  This replaces Tcl Environment Modules with Lmod.
SEMS_INIT=/projects/sems/modulefiles/utils/sems-modules-init.sh
if [ -f "$SEMS_INIT" ]; then
    HN=$(hostname)
    case "$HN" in
        hpws*|cee-*)
            source "$SEMS_INIT" 2>/dev/null
            module load aue/gcc/12.3.0 2>/dev/null
            module load aue/openmpi/4.1.6-gcc-12.3.0 2>/dev/null
            module load sems-cmake/3.31.8 2>/dev/null
            module load aue/boost/1.85.0-gcc-12.3.0-openmpi-4.1.6 2>/dev/null
            module load aue/hdf5/1.14.3-gcc-12.3.0-openmpi-4.1.6 2>/dev/null
            module load aue/netcdf-c/4.9.2-gcc-12.3.0-openmpi-4.1.6 2>/dev/null
            module load sems-googletest/1.17.0 2>/dev/null
            # Re-add LCM modulefiles since SEMS init resets MODULEPATH
            export MODULEPATH="$LCM_DIR/LCM/doc/LCM/modulefiles${MODULEPATH:+:$MODULEPATH}"
            ;;
    esac
fi

#---------------------------------------------------------------------------
# Parse arguments: extract commands, package, threads, and flags.
# Commands (clean, config, build, test) can be chained.
# Package and thread count are positional; flags start with --.
#---------------------------------------------------------------------------
COMMANDS=()
PACKAGE=""
THREADS="$(nproc)"
CDASH="OFF"
CTEST_VERBOSITY="-VV"

for arg in "$@"; do
    case "$arg" in
        --module=*)
            MODULE_NAME="${arg#--module=}"
            ;;
        --cdash)
            CDASH="ON"
            ;;
        --quiet|-q)
            CTEST_VERBOSITY="-V"
            ;;
        --help|-h)
            COMMANDS=(help)
            ;;
        clean|config|build|test|all|help)
            COMMANDS+=("$arg")
            ;;
        trilinos|lcm)
            PACKAGE="$arg"
            ;;
        [0-9]*)
            THREADS="$arg"
            ;;
    esac
done

# Default to help if no commands given
if [ ${#COMMANDS[@]} -eq 0 ]; then
    COMMANDS=(help)
fi

#---------------------------------------------------------------------------
# Help
#---------------------------------------------------------------------------
show_help() {
    cat <<'HELPTEXT'
LCM Build System CLI

Usage: lcm <commands...> <package> [threads] [options]

Commands (can be chained):
  clean                    Clean build (and install for trilinos) directories
  config                   Configure package
  build                    Build package with N threads (default: nproc)
  test                     Run tests for package
  all                      Full pipeline: clean + config + build + test
                           Builds trilinos then lcm
  help, --help, -h         Show this help

Packages:
  trilinos                 Trilinos (including DTK)
  lcm                      LCM/Albany

Options:
  --module=<name>          Module to load (default: release)
  --cdash                  Submit results to CDash
  --quiet, -q              Reduce ctest verbosity (-V instead of -VV)

Environment:
  LCM_DIR                  Workspace root (auto-detected if unset)
  LCM_MODULE               Module to load (default: release)

Examples:
  lcm clean trilinos                         # clean only
  lcm config build lcm 168                   # configure + build
  lcm clean config build lcm 32              # clean + configure + build
  lcm clean config build test lcm 168        # full pipeline for lcm
  lcm test lcm                               # test only
  lcm all 168                                # full pipeline (trilinos + lcm)
  lcm all 168 --module=serial-clang-release
  lcm all 168 --cdash -q
HELPTEXT
}

#---------------------------------------------------------------------------
# Validate package argument
#---------------------------------------------------------------------------
validate_package() {
    if [ -z "$PACKAGE" ]; then
        echo "ERROR: Package argument required. Use 'trilinos' or 'lcm'."
        exit 1
    fi
    case "$PACKAGE" in
        trilinos|lcm) ;;
        *)
            echo "ERROR: Unknown package '$PACKAGE'. Use 'trilinos' or 'lcm'."
            exit 1
            ;;
    esac
}

#---------------------------------------------------------------------------
# Load module and report environment
#---------------------------------------------------------------------------
load_module() {
    module purge 2>/dev/null || true
    module load "$MODULE_NAME"
    echo "Module:      $MODULE_NAME"
    echo "LCM_DIR:     $LCM_DIR"
    echo "ARCH:        ${ARCH:-unset}"
    echo "TOOL_CHAIN:  ${TOOL_CHAIN:-unset}"
    echo "BUILD_TYPE:  ${BUILD_TYPE:-unset}"
    echo "Threads:     $THREADS"
}

#---------------------------------------------------------------------------
# Run ctest -S with explicit -D flags
#---------------------------------------------------------------------------
run_ctest() {
    local CLEAN_BUILD="${1:-OFF}"
    local DO_CONFIG="${2:-OFF}"
    local DO_BUILD="${3:-OFF}"
    local DO_TEST="${4:-OFF}"

    local BUILD_SCRIPT="$LCM_DIR/LCM/doc/LCM/build/lcm_build.cmake"

    if [ ! -f "$BUILD_SCRIPT" ]; then
        echo "ERROR: Cannot find $BUILD_SCRIPT"
        exit 1
    fi

    cd "$LCM_DIR"

    echo "Running: ctest $CTEST_VERBOSITY -S lcm_build.cmake"
    echo "  PACKAGE=$PACKAGE  CLEAN_BUILD=$CLEAN_BUILD"
    echo "  DO_CONFIG=$DO_CONFIG  DO_BUILD=$DO_BUILD  DO_TEST=$DO_TEST"
    echo "  BUILD_THREADS=$THREADS"

    local BUILD_ID_STRING="${ARCH}-${TOOL_CHAIN}-${BUILD_TYPE}"
    local PREFIX="${PACKAGE}-${BUILD_ID_STRING}"
    local LOG_FILE="$LCM_DIR/${PREFIX}.log"

    ctest $CTEST_VERBOSITY --timeout 180 -S "$BUILD_SCRIPT" \
        -DPACKAGE:STRING="$PACKAGE" \
        -DBUILD_THREADS:STRING="$THREADS" \
        -DCLEAN_BUILD:BOOL="$CLEAN_BUILD" \
        -DDO_CONFIG:BOOL="$DO_CONFIG" \
        -DDO_BUILD:BOOL="$DO_BUILD" \
        -DDO_TEST:BOOL="$DO_TEST" \
        -DCTEST_DO_SUBMIT:BOOL="$CDASH" \
        | tee "$LOG_FILE"
}

#---------------------------------------------------------------------------
# Command dispatch
#---------------------------------------------------------------------------

# Handle help and all as special cases
for CMD in "${COMMANDS[@]}"; do
    if [ "$CMD" = "help" ]; then
        show_help
        exit 0
    fi
    if [ "$CMD" = "all" ]; then
        load_module
        echo "=== Full pipeline: trilinos + lcm ==="

        echo "--- Trilinos: clean + config + build ($THREADS threads) ---"
        PACKAGE=trilinos
        run_ctest ON ON ON OFF

        echo "--- LCM: clean + config + build + test ($THREADS threads) ---"
        PACKAGE=lcm
        run_ctest ON ON ON ON

        echo "=== Full pipeline complete ==="
        exit 0
    fi
done

# For chained commands, build up the flags and run once
validate_package
load_module

DO_CLEAN=OFF
DO_CONFIG=OFF
DO_BUILD=OFF
DO_TEST=OFF

for CMD in "${COMMANDS[@]}"; do
    case "$CMD" in
        clean)  DO_CLEAN=ON ;;
        config) DO_CONFIG=ON ;;
        build)  DO_BUILD=ON ;;
        test)   DO_TEST=ON ;;
    esac
done

echo "--- $PACKAGE: clean=$DO_CLEAN config=$DO_CONFIG build=$DO_BUILD test=$DO_TEST ($THREADS threads) ---"
run_ctest $DO_CLEAN $DO_CONFIG $DO_BUILD $DO_TEST
