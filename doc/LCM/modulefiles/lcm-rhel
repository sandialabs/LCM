#%Module 1.0

module-whatis "LCM RHEL base environment"

setenv LCM_ENV_TYPE RHEL

if { ![ file exists /etc/redhat-release ] } {
  puts stderr "lcm-rhel can only be loaded on RHEL systems !"
  exit 1
}

module load lcm-common

# Newer Trilinos requires CMake >= 3.27 (system may have older).
# Discover the spack-installed cmake by hash-agnostic query so this works
# on any host with /opt/spack and cmake@3.27.9 installed via spack.
if { [ file exists /opt/spack/bin/spack ] } {
  if { ![catch {exec /opt/spack/bin/spack location -i cmake@3.27.9} cmake_spack_dir] } {
    if { [ file exists $cmake_spack_dir/bin/cmake ] } {
      prepend-path PATH $cmake_spack_dir/bin
    }
  }
}

conflict lcm-fedora lcm-ubuntu
