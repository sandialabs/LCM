#%Module 1.0
module-whatis "LCM TPLs for Trilinos/Albany"

if { [is-loaded lcm-cee] } {
  # On CEE LAN, the lcm build script loads AUE/SEMS modules via Lmod
  # before these Tcl modules run.  Read paths from the env vars they set.
  if { [info exists ::env(BOOST_ROOT)] } {
    setenv BOOST_INC    $::env(BOOST_ROOT)/include
    setenv BOOST_LIB    $::env(BOOST_ROOT)/lib
    setenv BOOSTLIB_INC $::env(BOOST_ROOT)/include
    setenv BOOSTLIB_LIB $::env(BOOST_ROOT)/lib
  }
  if { [info exists ::env(NETCDF_ROOT)] } {
    setenv NETCDF       $::env(NETCDF_ROOT)
    setenv NETCDF_INC   $::env(NETCDF_ROOT)/include
    setenv NETCDF_LIB   $::env(NETCDF_ROOT)/lib
  }
  # MPI paths are exported by the lcm build script after loading
  # AUE modules.  The Tcl module just needs to propagate them.
  if { [info exists ::env(MPI_BIN)] } {
    setenv MPI_BIN $::env(MPI_BIN)
    setenv MPI_INC $::env(MPI_INC)
    setenv MPI_LIB $::env(MPI_LIB)
  }
} elseif { [is-loaded lcm-fedora] } {
  setenv BOOST_INC       /usr/include/boost
  setenv BOOST_LIB       /usr/lib64
  setenv BOOSTLIB_INC    /usr/include/boost
  setenv BOOSTLIB_LIB    /usr/lib64
  setenv MPI_INC         /usr/include/openmpi-x86_64
  setenv MPI_LIB         /usr/lib64/openmpi/lib
  setenv MPI_BIN         /usr/lib64/openmpi/bin
  setenv NETCDF          /usr
  setenv NETCDF_INC      /usr/include
  setenv NETCDF_LIB      /usr/lib64
  prepend-path PATH      /usr/lib64/openmpi/bin
} elseif { [is-loaded lcm-ubuntu] } {
  setenv BOOST_INC       /usr/include/boost
  setenv BOOST_LIB       /usr/lib/x86_64-linux-gnu
  setenv BOOSTLIB_INC    /usr/include/boost
  setenv BOOSTLIB_LIB    /usr/lib/x86_64-linux-gnu
  setenv MPI_INC         /usr/lib/openmpi/include
  setenv MPI_LIB         /usr/lib/openmpi/lib
  setenv MPI_BIN         /usr/bin
  setenv NETCDF          /usr
  setenv NETCDF_INC      /usr/include
  setenv NETCDF_LIB      /usr/lib/x86_64-linux-gnu
} elseif { [is-loaded lcm-rhel] } {
  setenv BOOST_INC       /usr/include/boost
  setenv BOOST_LIB       /usr/lib64
  setenv BOOSTLIB_INC    /usr/include/boost
  setenv BOOSTLIB_LIB    /usr/lib64
  setenv MPI_INC         /usr/include/openmpi-x86_64
  setenv MPI_LIB         /usr/lib64/openmpi/lib
  setenv MPI_BIN         /usr/lib64/openmpi/bin
  setenv NETCDF          /usr
  setenv NETCDF_INC      /usr/include
  setenv NETCDF_LIB      /usr/lib64
  if { [ file exists /lib64/libflexiblas.so ] } {
    setenv BLAS_LIB      /lib64/libopenblas.so
    setenv LAPACK_LIB    /lib64/libopenblas.so
  }
  prepend-path PATH      /usr/lib64/openmpi/bin
}
