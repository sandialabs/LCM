COORDINATES absolute 1.e-6

TIME STEPS relative 1.e-6 floor 0.0

# Tolerances are sized to absorb cross-build / reduction-order noise while
# still catching real regressions. The cap-plasticity (Permafrost) model is
# more floating-point divergent across compilers than J2 erosion (explicit
# Sloan substepping + spectral eig_sym), so the engineering quantities are
# checked RELATIVE, and the near-zero kinematic fields (velocity,
# acceleration), which are physically ~0 in this quasi-static problem, are
# checked ABSOLUTE with a small floor. Displacements -- the meaningful
# mechanical response -- stay at relative 2e-5.
NODAL VARIABLES relative 2.0e-5 floor 1.0e-5
	temperature        relative 6.0e-6 floor 1.0e-12
	temperature_dot    relative 6.0e-6 floor 1.0e-12
	displacement_x
	displacement_y
	displacement_z
	velocity_x               absolute 1.0e-4 floor 1.0e-6
	velocity_y               absolute 1.0e-4 floor 1.0e-6
	velocity_z               absolute 1.0e-4 floor 1.0e-6
	acceleration_x           absolute 1.0e-5 floor 1.0e-6
	acceleration_y           absolute 1.0e-5 floor 1.0e-6
	acceleration_z           absolute 1.0e-5 floor 1.0e-6
	displacement_residual_x  absolute 1.0e-5 floor 1.0e-6
	displacement_residual_y  absolute 1.0e-5 floor 1.0e-6
	displacement_residual_z  absolute 1.0e-5 floor 1.0e-6
	proj_nodal_linear        absolute 1.0e-12 floor 1.0e-12

# Element quantities (Cauchy_Stress ~ O(1e4), eqps, plastic strain, failure
# state/modes) are checked relative. The large stresses agree to ~1e-8, but
# small-magnitude stress components drift up to ~6e-5 across compilers, so the
# relative tolerance is 2e-4. The floor drops near-zero shear-stress noise
# (~1e-7) without masking a changed failure mode (a flipped 0->bit is rel
# diff 1.0).
ELEMENT VARIABLES relative 2.0e-4 floor 1.0e-3
