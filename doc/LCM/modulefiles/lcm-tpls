#%Module 1.0

module-whatis "LCM TPLs for Trilinos/Albany"

if { [is-loaded lcm-fedora] } {
  set                     netcdf_root     /usr
  set                     netcdf_inc      $netcdf_root/include
  set                     netcdf_lib      $netcdf_root/lib64
  setenv                  BOOST_INC       /usr/include/boost
  setenv                  BOOST_LIB       /usr/lib64
  setenv                  BOOSTLIB_INC    /usr/include/boost
  setenv                  BOOSTLIB_LIB    /usr/lib64
  setenv                  MPI_INC         /usr/include/openmpi-x86_64
  setenv                  MPI_LIB         /usr/lib64/openmpi/lib
  setenv                  MPI_BIN         /usr/lib64/openmpi/bin
  setenv                  NETCDF          $netcdf_root
  setenv                  NETCDF_INC      $netcdf_inc
  setenv                  NETCDF_LIB      $netcdf_lib
  prepend-path            PATH            /usr/lib64/openmpi/bin
  continue
}

if { [is-loaded lcm-ubuntu] } {
  set                     netcdf_root     /usr
  set                     netcdf_inc      $netcdf_root/include
  set                     netcdf_lib      $netcdf_root/lib/x86_64-linux-gnu
  setenv                  BOOST_INC       /usr/include/boost
  setenv                  BOOST_LIB       /usr/lib
  setenv                  BOOSTLIB_INC    /usr/include/boost
  setenv                  BOOSTLIB_LIB    /usr/lib
  setenv                  MPI_INC         /usr/lib/openmpi/include
  setenv                  MPI_LIB         /usr/lib/openmpi/lib
  setenv                  MPI_BIN         /usr/bin
  setenv                  NETCDF          $netcdf_root
  setenv                  NETCDF_INC      $netcdf_inc
  setenv                  NETCDF_LIB      $netcdf_lib
  continue
}

if { [is-loaded lcm-cee] } {
  # On CEE LAN, load SEMS v2 modules for TPLs.
  # The SEMS modules are hierarchical Lua/Lmod modules under
  # /projects/sems/modulefiles/rhel8-x86_64/sems/linux-rhel8-x86_64/
  # After loading sems-gcc + sems-openmpi, the TPL modules become visible.
  # The SEMS modules set BOOST_INC, BOOST_LIB, OPENMPI_BIN, etc.
  # We map them to the names the LCM build system expects.

  module load sems-cmake
  module load sems-boost
  module load sems-openmpi
  module load sems-hdf5
  module load sems-netcdf-c
  module load sems-googletest

  # Map SEMS env vars to LCM build system expectations
  setenv MPI_INC   $env(OPENMPI_INC)
  setenv MPI_LIB   $env(OPENMPI_LIB)
  setenv MPI_BIN   $env(OPENMPI_BIN)
  setenv BOOSTLIB_INC $env(BOOST_INC)
  setenv BOOSTLIB_LIB $env(BOOST_LIB)
  set    netcdf_inc   $env(NETCDF_C_INC)
  set    netcdf_lib   $env(NETCDF_C_LIB)
  setenv NETCDF       $env(NETCDF_C_ROOT)
  setenv NETCDF_INC   $netcdf_inc
  setenv NETCDF_LIB   $netcdf_lib

  prepend-path PATH $env(OPENMPI_BIN)
  continue
}

if { [is-loaded lcm-rhel] } {
  set                     netcdf_root     /usr
  set                     netcdf_inc      $netcdf_root/include
  set                     netcdf_lib      $netcdf_root/lib64
  setenv                  BOOST_INC       /usr/include/boost
  setenv                  BOOST_LIB       /usr/lib64
  setenv                  BOOSTLIB_INC    /usr/include/boost
  setenv                  BOOSTLIB_LIB    /usr/lib64
  setenv                  MPI_INC         /usr/include/openmpi-x86_64
  setenv                  MPI_LIB         /usr/lib64/openmpi/lib
  setenv                  MPI_BIN         /usr/lib64/openmpi/bin
  setenv                  NETCDF          $netcdf_root
  setenv                  NETCDF_INC      $netcdf_inc
  setenv                  NETCDF_LIB      $netcdf_lib
  if { [ file exists /lib64/libflexiblas.so ] } {
    setenv                  BLAS_LIB        /lib64/libopenblas.so
    setenv                  LAPACK_LIB      /lib64/libopenblas.so
  }
  prepend-path            PATH            /usr/lib64/openmpi/bin
  continue
}
