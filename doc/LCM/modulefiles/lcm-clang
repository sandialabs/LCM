#%Module 1.0

module-whatis "LCM Clang compiler"

setenv TOOL_CHAIN clang

if { [is-loaded lcm-cee] } {
  # On CEE LAN, load the SEMS Clang module
  module load sems-clang/19.1.3
  setenv CC [exec which clang]
  setenv CXX [exec which clang++]
  setenv FC [exec which gfortran]
} else {
  # Use system Clang
  setenv CC [exec which clang]
  setenv CXX [exec which clang++]
  setenv FC [exec which gfortran]
}

if { [is-loaded lcm-fedora] } {
  setenv CXXFLAGS "-std=c++20 -Wno-implicit-int-float-conversion"
} else {
  setenv CXXFLAGS "-std=c++20"
}
